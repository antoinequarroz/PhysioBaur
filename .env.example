# SMTP credentials used by server/api/contact.post.ts to send the contact form by email.
# Any SMTP provider works (Infomaniak, Gmail with an app password, etc.).
NUXT_SMTP_HOST=mail.infomaniak.com
NUXT_SMTP_PORT=587
NUXT_SMTP_USER=info@physiobaur.ch
NUXT_SMTP_PASS=
NUXT_CONTACT_TO_EMAIL=info@physiobaur.ch

# Cloudflare Turnstile (free) - create a widget at https://dash.cloudflare.com/?to=/:account/turnstile
# Site key is public (shown in the form), secret key must stay private.
NUXT_PUBLIC_TURNSTILE_SITE_KEY=
NUXT_TURNSTILE_SECRET_KEY=
